{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Bibliography Block",
    "description": "Launch WordPress Playground with the Bibliography Block plugin installed for quick evaluation.",
    "author": "danknauss",
    "categories": ["plugin", "bibliography", "block-editor"]
  },
  "landingPage": "/wp-admin/post-new.php",
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/dknauss/wp-bibliography-block/releases/latest/download/bibliography-block.zip"
      },
      "options": {
        "activate": true,
        "targetFolderName": "scholarly-bibliography"
      }
    }
  ]
}
