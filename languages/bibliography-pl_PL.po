msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Zaimportowane metadane mogą być niepełne. Zweryfikuj je przed publikacją."

msgid "Add citations"
msgstr "Dodaj cytowania"

msgid "Paste / Import"
msgstr "Wklej / importuj"

msgid "Manual Entry"
msgstr "Wprowadzanie ręczne"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Dodaj DOI, wpisy BibTeX i cytowania w obsługiwanych stylach dla książek, artykułów, rozdziałów i stron internetowych. Oddziel wiele sformatowanych cytowań pustą linią."

msgid "Resolving…"
msgstr "Przetwarzanie…"

msgid "Add"
msgstr "Dodaj"

msgid "Clear"
msgstr "Wyczyść"

msgid "Author(s)"
msgstr "Autor(zy)"

msgid "Title"
msgstr "Tytuł"

msgid "Container"
msgstr "Kontener"

msgid "Publisher"
msgstr "Wydawca"

msgid "Year"
msgstr "Rok"

msgid "Pages"
msgstr "Strony"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Ukryj formularz cytowania"

msgid "Show citation form"
msgstr "Pokaż formularz cytowania"

msgid "Settings"
msgstr "Ustawienia"

msgid "source"
msgstr "źródło"

msgid "sources"
msgstr "źródła"

msgid "Citation Style"
msgstr "Styl cytowania"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Zmiana stylu ponownie formatuje cytowania generowane automatycznie i zachowuje ręczne nadpisania."

msgid "Visible Heading"
msgstr "Widoczny nagłówek"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Opcjonalny nagłówek wyświetlany nad bibliografią w publicznej części witryny, gdy istnieje co najmniej jedno cytowanie."

msgid "Output JSON-LD"
msgstr "Wyświetl JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Pomaga wyszukiwarkom i innym narzędziom zrozumieć bibliografię."

msgid "Output COinS"
msgstr "Wyświetl COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Pozwala Zotero i podobnym narzędziom wykrywać cytowania na stronie."

msgid "Output CSL-JSON"
msgstr "Wyświetl CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Umożliwia ponowne wykorzystanie danych cytowań przez narzędzia i usługi naukowe."

msgid "Exports"
msgstr "Eksporty"

msgid "Copy bibliography"
msgstr "Kopiuj bibliografię"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Kopiuje bieżącą bibliografię jako zwykły tekst w bieżącej kolejności i stylu."

msgid "Download CSL-JSON"
msgstr "Pobierz CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Pobiera bieżącą bibliografię jako uporządkowane dane cytowań."

msgid "Download BibTeX"
msgstr "Pobierz BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Pobiera bieżącą bibliografię jako BibTeX do menedżerów bibliografii i akademickich przepływów pracy."

msgid "Download RIS"
msgstr "Pobierz RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Pobiera bieżącą bibliografię jako RIS dla menedżerów cytowań i procesów importu/eksportu."

msgid "Notification"
msgstr "Powiadomienie"

msgid "Publication Type"
msgstr "Typ publikacji"

msgid "Select a publication type"
msgstr "Wybierz typ publikacji"

msgid "Save"
msgstr "Zapisz"

msgid "Cancel"
msgstr "Anuluj"

msgid "Post not found."
msgstr "Nie znaleziono wpisu."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Niestety nie masz uprawnień do odczytu tej bibliografii."

msgid "Bibliography block not found for the requested index."
msgstr "Nie znaleziono bloku bibliografii dla żądanego indeksu."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID wpisu do sprawdzenia pod kątem bloków bibliografii."

msgid "Zero-based bibliography block index within the post."
msgstr "Indeks bloku bibliografii w wpisie oparty na zerze."

msgid "Response format: json, text, or csl-json."
msgstr "Format odpowiedzi: json, text lub csl-json."
