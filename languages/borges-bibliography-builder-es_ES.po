msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Los metadatos importados pueden estar incompletos. Verifícalos antes de publicar."

msgid "Add citations"
msgstr "Añadir citas"

msgid "Paste / Import"
msgstr "Pegar / Importar"

msgid "Manual Entry"
msgstr "Entrada manual"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Añade DOI, entradas BibTeX y citas en estilos compatibles para libros, artículos, capítulos y páginas web. Separa varias citas formateadas con una línea en blanco."

msgid "Resolving…"
msgstr "Resolviendo…"

msgid "Add"
msgstr "Añadir"

msgid "Clear"
msgstr "Borrar"

msgid "Author(s)"
msgstr "Autor(es)"

msgid "Title"
msgstr "Título"

msgid "Container"
msgstr "Contenedor"

msgid "Publisher"
msgstr "Editorial"

msgid "Year"
msgstr "Año"

msgid "Pages"
msgstr "Páginas"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Ocultar formulario de citas"

msgid "Show citation form"
msgstr "Mostrar formulario de citas"

msgid "Settings"
msgstr "Ajustes"

msgid "source"
msgstr "fuente"

msgid "sources"
msgstr "fuentes"

msgid "Citation Style"
msgstr "Estilo de cita"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Cambiar de estilo vuelve a formatear las citas generadas automáticamente y mantiene intactas las modificaciones manuales."

msgid "Visible Heading"
msgstr "Encabezado visible"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Encabezado opcional que se muestra encima de la bibliografía en la parte pública del sitio cuando existe al menos una cita."

msgid "Output JSON-LD"
msgstr "Mostrar JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Ayuda a los motores de búsqueda y otras herramientas a comprender la bibliografía."

msgid "Output COinS"
msgstr "Mostrar COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Permite que Zotero y herramientas similares detecten citas en la página."

msgid "Output CSL-JSON"
msgstr "Mostrar CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Hace que los datos de citación sean reutilizables por herramientas y servicios académicos."

msgid "Exports"
msgstr "Exportaciones"

msgid "Copy bibliography"
msgstr "Copiar bibliografía"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Copia la bibliografía actual como texto sin formato en el orden y estilo actuales."

msgid "Download CSL-JSON"
msgstr "Descargar CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Descarga la bibliografía actual como datos de citación estructurados."

msgid "Download BibTeX"
msgstr "Descargar BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Descarga la bibliografía actual como BibTeX para gestores de referencias y flujos de escritura académica."

msgid "Download RIS"
msgstr "Descargar RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Descarga la bibliografía actual como RIS para gestores de citas y flujos de importación/exportación."

msgid "Notification"
msgstr "Notificación"

msgid "Publication Type"
msgstr "Tipo de publicación"

msgid "Select a publication type"
msgstr "Selecciona un tipo de publicación"

msgid "Save"
msgstr "Guardar"

msgid "Cancel"
msgstr "Cancelar"

msgid "Post not found."
msgstr "No se ha encontrado la entrada."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Lo siento, no tienes permisos para leer esta bibliografía."

msgid "Bibliography block not found for the requested index."
msgstr "No se ha encontrado un bloque de bibliografía para el índice solicitado."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID de la entrada que se debe inspeccionar para buscar bloques de bibliografía."

msgid "Zero-based bibliography block index within the post."
msgstr "Índice basado en cero del bloque de bibliografía dentro de la entrada."

msgid "Response format: json, text, or csl-json."
msgstr "Formato de respuesta: json, text o csl-json."
