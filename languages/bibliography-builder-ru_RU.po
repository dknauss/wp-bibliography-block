msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Импортированные метаданные могут быть неполными. Проверьте их перед публикацией."

msgid "Add citations"
msgstr "Добавить цитаты"

msgid "Paste / Import"
msgstr "Вставить / Импортировать"

msgid "Manual Entry"
msgstr "Ручной ввод"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Добавляйте DOI, записи BibTeX и цитаты в поддерживаемых стилях для книг, статей, глав и веб-страниц. Разделяйте несколько отформатированных цитат пустой строкой."

msgid "Resolving…"
msgstr "Обработка…"

msgid "Add"
msgstr "Добавить"

msgid "Clear"
msgstr "Очистить"

msgid "Author(s)"
msgstr "Автор(ы)"

msgid "Title"
msgstr "Название"

msgid "Container"
msgstr "Контейнер"

msgid "Publisher"
msgstr "Издатель"

msgid "Year"
msgstr "Год"

msgid "Pages"
msgstr "Страницы"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Скрыть форму цитирования"

msgid "Show citation form"
msgstr "Показать форму цитирования"

msgid "Settings"
msgstr "Настройки"

msgid "source"
msgstr "источник"

msgid "sources"
msgstr "источники"

msgid "Citation Style"
msgstr "Стиль цитирования"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Смена стиля переформатирует автоматически созданные цитаты и сохраняет ручные переопределения."

msgid "Visible Heading"
msgstr "Видимый заголовок"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Необязательный заголовок, отображаемый над библиографией на сайте, если существует хотя бы одна цитата."

msgid "Output JSON-LD"
msgstr "Выводить JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Помогает поисковым системам и другим инструментам понимать библиографию."

msgid "Output COinS"
msgstr "Выводить COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Позволяет Zotero и похожим инструментам обнаруживать цитаты на странице."

msgid "Output CSL-JSON"
msgstr "Выводить CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Делает данные цитирования пригодными для повторного использования научными инструментами и сервисами."

msgid "Exports"
msgstr "Экспорт"

msgid "Copy bibliography"
msgstr "Копировать библиографию"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Копирует текущую библиографию как обычный текст в текущем порядке и стиле."

msgid "Download CSL-JSON"
msgstr "Скачать CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Скачивает текущую библиографию как структурированные данные цитирования."

msgid "Download BibTeX"
msgstr "Скачать BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Скачивает текущую библиографию как BibTeX для менеджеров ссылок и научных рабочих процессов."

msgid "Download RIS"
msgstr "Скачать RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Скачивает текущую библиографию как RIS для менеджеров цитирования и процессов импорта/экспорта."

msgid "Notification"
msgstr "Уведомление"

msgid "Publication Type"
msgstr "Тип публикации"

msgid "Select a publication type"
msgstr "Выберите тип публикации"

msgid "Save"
msgstr "Сохранить"

msgid "Cancel"
msgstr "Отмена"

msgid "Post not found."
msgstr "Запись не найдена."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "У вас нет прав для просмотра этой библиографии."

msgid "Bibliography block not found for the requested index."
msgstr "Блок библиографии для указанного индекса не найден."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID записи для проверки на наличие блоков библиографии."

msgid "Zero-based bibliography block index within the post."
msgstr "Индекс блока библиографии внутри записи, начинающийся с нуля."

msgid "Response format: json, text, or csl-json."
msgstr "Формат ответа: json, text или csl-json."
