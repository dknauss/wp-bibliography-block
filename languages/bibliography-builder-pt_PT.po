msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Os metadados importados podem estar incompletos. Verifique-os antes de publicar."

msgid "Add citations"
msgstr "Adicionar citações"

msgid "Paste / Import"
msgstr "Colar / Importar"

msgid "Manual Entry"
msgstr "Introdução manual"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Adicione DOI, entradas BibTeX e citações em estilos suportados para livros, artigos, capítulos e páginas web. Separe várias citações formatadas com uma linha em branco."

msgid "Resolving…"
msgstr "A processar…"

msgid "Add"
msgstr "Adicionar"

msgid "Clear"
msgstr "Limpar"

msgid "Author(s)"
msgstr "Autor(es)"

msgid "Title"
msgstr "Título"

msgid "Container"
msgstr "Contentor"

msgid "Publisher"
msgstr "Editora"

msgid "Year"
msgstr "Ano"

msgid "Pages"
msgstr "Páginas"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Ocultar formulário de citação"

msgid "Show citation form"
msgstr "Mostrar formulário de citação"

msgid "Settings"
msgstr "Definições"

msgid "source"
msgstr "fonte"

msgid "sources"
msgstr "fontes"

msgid "Citation Style"
msgstr "Estilo de citação"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Alterar estilos reformata as citações geradas automaticamente e mantém intactas as substituições manuais."

msgid "Visible Heading"
msgstr "Cabeçalho visível"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Cabeçalho opcional apresentado acima da bibliografia na frente do site quando existe pelo menos uma citação."

msgid "Output JSON-LD"
msgstr "Emitir JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Ajuda os motores de pesquisa e outras ferramentas a compreender a bibliografia."

msgid "Output COinS"
msgstr "Emitir COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Permite ao Zotero e a ferramentas semelhantes detectar citações na página."

msgid "Output CSL-JSON"
msgstr "Emitir CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Torna os dados de citação reutilizáveis por ferramentas e serviços académicos."

msgid "Exports"
msgstr "Exportações"

msgid "Copy bibliography"
msgstr "Copiar bibliografia"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Copia a bibliografia atual como texto simples na ordem e no estilo atuais."

msgid "Download CSL-JSON"
msgstr "Descarregar CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Descarrega a bibliografia atual como dados de citação estruturados."

msgid "Download BibTeX"
msgstr "Descarregar BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Descarrega a bibliografia atual como BibTeX para gestores de referências e fluxos de escrita académica."

msgid "Download RIS"
msgstr "Descarregar RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Descarrega a bibliografia atual como RIS para gestores de citações e fluxos de importação/exportação."

msgid "Notification"
msgstr "Notificação"

msgid "Publication Type"
msgstr "Tipo de publicação"

msgid "Select a publication type"
msgstr "Selecione um tipo de publicação"

msgid "Save"
msgstr "Guardar"

msgid "Cancel"
msgstr "Cancelar"

msgid "Post not found."
msgstr "Conteúdo não encontrado."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Não tem permissão para ler esta bibliografia."

msgid "Bibliography block not found for the requested index."
msgstr "Bloco de bibliografia não encontrado para o índice solicitado."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID do conteúdo a inspecionar para blocos de bibliografia."

msgid "Zero-based bibliography block index within the post."
msgstr "Índice do bloco de bibliografia com base zero dentro do conteúdo."

msgid "Response format: json, text, or csl-json."
msgstr "Formato da resposta: json, text ou csl-json."
