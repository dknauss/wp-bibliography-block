msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Uvezeni metapodaci mogu biti nepotpuni. Provjerite ih prije objave."

msgid "Add citations"
msgstr "Dodaj citate"

msgid "Paste / Import"
msgstr "Zalijepi / Uvezi"

msgid "Manual Entry"
msgstr "Ručni unos"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Dodajte DOI-je, BibTeX unose i citate u podržanim stilovima za knjige, članke, poglavlja i web-stranice. Više formatiranih citata odvojite praznim redom."

msgid "Resolving…"
msgstr "Obrada…"

msgid "Add"
msgstr "Dodaj"

msgid "Clear"
msgstr "Očisti"

msgid "Author(s)"
msgstr "Autor(i)"

msgid "Title"
msgstr "Naslov"

msgid "Container"
msgstr "Kontejner"

msgid "Publisher"
msgstr "Izdavač"

msgid "Year"
msgstr "Godina"

msgid "Pages"
msgstr "Stranice"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Sakrij obrazac citata"

msgid "Show citation form"
msgstr "Prikaži obrazac citata"

msgid "Settings"
msgstr "Postavke"

msgid "source"
msgstr "izvor"

msgid "sources"
msgstr "izvori"

msgid "Citation Style"
msgstr "Stil citiranja"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Promjena stila ponovno formatira automatski generirane citate i zadržava ručna prepisivanja."

msgid "Visible Heading"
msgstr "Vidljivi naslov"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Neobavezni naslov prikazan iznad bibliografije na javnom dijelu stranice kada postoji barem jedan citat."

msgid "Output JSON-LD"
msgstr "Prikaži JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Pomaže tražilicama i drugim alatima da razumiju bibliografiju."

msgid "Output COinS"
msgstr "Prikaži COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Omogućuje Zotero-u i sličnim alatima otkrivanje citata na stranici."

msgid "Output CSL-JSON"
msgstr "Prikaži CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Omogućuje ponovnu uporabu podataka o citiranju u akademskim alatima i uslugama."

msgid "Exports"
msgstr "Izvoz"

msgid "Copy bibliography"
msgstr "Kopiraj bibliografiju"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Kopira trenutačnu bibliografiju kao običan tekst u trenutačnom redoslijedu i stilu."

msgid "Download CSL-JSON"
msgstr "Preuzmi CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Preuzima trenutačnu bibliografiju kao strukturirane podatke o citiranju."

msgid "Download BibTeX"
msgstr "Preuzmi BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Preuzima trenutačnu bibliografiju kao BibTeX za upravitelje referenci i akademske tijekove pisanja."

msgid "Download RIS"
msgstr "Preuzmi RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Preuzima trenutačnu bibliografiju kao RIS za upravitelje citata i tijekove uvoza/izvoza."

msgid "Notification"
msgstr "Obavijest"

msgid "Publication Type"
msgstr "Vrsta publikacije"

msgid "Select a publication type"
msgstr "Odaberite vrstu publikacije"

msgid "Save"
msgstr "Spremi"

msgid "Cancel"
msgstr "Odustani"

msgid "Post not found."
msgstr "Objava nije pronađena."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Nemate dopuštenje za čitanje ove bibliografije."

msgid "Bibliography block not found for the requested index."
msgstr "Blok bibliografije nije pronađen za traženi indeks."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID objave za provjeru blokova bibliografije."

msgid "Zero-based bibliography block index within the post."
msgstr "Indeks bloka bibliografije unutar objave koji počinje od nule."

msgid "Response format: json, text, or csl-json."
msgstr "Format odgovora: json, text ili csl-json."
