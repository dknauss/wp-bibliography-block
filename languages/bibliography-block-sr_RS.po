msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Увезени метаподаци могу бити непотпуни. Проверите их пре објављивања."

msgid "Add citations"
msgstr "Додај цитате"

msgid "Paste / Import"
msgstr "Налепи / Увези"

msgid "Manual Entry"
msgstr "Ручни унос"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Додајте DOI, BibTeX уносе и цитате у подржаним стиловима за књиге, чланке, поглавља и веб-странице. Одвојите више форматираних цитата празним редом."

msgid "Resolving…"
msgstr "Обрада…"

msgid "Add"
msgstr "Додај"

msgid "Clear"
msgstr "Очисти"

msgid "Author(s)"
msgstr "Аутор(и)"

msgid "Title"
msgstr "Наслов"

msgid "Container"
msgstr "Контејнер"

msgid "Publisher"
msgstr "Издавач"

msgid "Year"
msgstr "Година"

msgid "Pages"
msgstr "Странице"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Сакриј образац за цитирање"

msgid "Show citation form"
msgstr "Прикажи образац за цитирање"

msgid "Settings"
msgstr "Подешавања"

msgid "source"
msgstr "извор"

msgid "sources"
msgstr "извори"

msgid "Citation Style"
msgstr "Стил цитирања"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Промена стила поново форматира аутоматски генерисане цитате и задржава ручне измене."

msgid "Visible Heading"
msgstr "Видљиви наслов"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Опциони наслов приказан изнад библиографије на предњем делу сајта када постоји бар један цитат."

msgid "Output JSON-LD"
msgstr "Прикажи JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Помаже претраживачима и другим алатима да разумеју библиографију."

msgid "Output COinS"
msgstr "Прикажи COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Омогућава Zotero-у и сличним алатима да открију цитате на страници."

msgid "Output CSL-JSON"
msgstr "Прикажи CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Омогућава поновну употребу података о цитирању у научним алатима и сервисима."

msgid "Exports"
msgstr "Извози"

msgid "Copy bibliography"
msgstr "Копирај библиографију"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Копира тренутну библиографију као обичан текст у тренутном редоследу и стилу."

msgid "Download CSL-JSON"
msgstr "Преузми CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Преузима тренутну библиографију као структуриране податке о цитирању."

msgid "Download BibTeX"
msgstr "Преузми BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Преузима тренутну библиографију као BibTeX за менаџере референци и научне токове писања."

msgid "Download RIS"
msgstr "Преузми RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Преузима тренутну библиографију као RIS за менаџере цитата и токове увоза/извоза."

msgid "Notification"
msgstr "Обавештење"

msgid "Publication Type"
msgstr "Тип публикације"

msgid "Select a publication type"
msgstr "Изаберите тип публикације"

msgid "Save"
msgstr "Сачувај"

msgid "Cancel"
msgstr "Откажи"

msgid "Post not found."
msgstr "Чланак није пронађен."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Немате дозволу да читате ову библиографију."

msgid "Bibliography block not found for the requested index."
msgstr "Библиографски блок није пронађен за тражени индекс."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID чланка за проверу библиографских блокова."

msgid "Zero-based bibliography block index within the post."
msgstr "Индекс библиографског блока у чланку који почиње од нуле."

msgid "Response format: json, text, or csl-json."
msgstr "Формат одговора: json, text или csl-json."
