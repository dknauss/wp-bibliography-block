msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "Les métadonnées importées peuvent être incomplètes. Vérifiez-les avant publication."

msgid "Add citations"
msgstr "Ajouter des citations"

msgid "Paste / Import"
msgstr "Coller / Importer"

msgid "Manual Entry"
msgstr "Saisie manuelle"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "Ajoutez des DOI, des entrées BibTeX et des citations dans des styles pris en charge pour les livres, articles, chapitres et pages web. Séparez plusieurs citations formatées par une ligne vide."

msgid "Resolving…"
msgstr "Résolution…"

msgid "Add"
msgstr "Ajouter"

msgid "Clear"
msgstr "Effacer"

msgid "Author(s)"
msgstr "Auteur(s)"

msgid "Title"
msgstr "Titre"

msgid "Container"
msgstr "Conteneur"

msgid "Publisher"
msgstr "Éditeur"

msgid "Year"
msgstr "Année"

msgid "Pages"
msgstr "Pages"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Masquer le formulaire de citation"

msgid "Show citation form"
msgstr "Afficher le formulaire de citation"

msgid "Settings"
msgstr "Réglages"

msgid "source"
msgstr "source"

msgid "sources"
msgstr "sources"

msgid "Citation Style"
msgstr "Style de citation"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "Le changement de style reformate les citations générées automatiquement et conserve les remplacements manuels."

msgid "Visible Heading"
msgstr "Titre visible"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "Titre facultatif affiché au-dessus de la bibliographie sur le site lorsqu’au moins une citation existe."

msgid "Output JSON-LD"
msgstr "Produire du JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Aide les moteurs de recherche et d’autres outils à comprendre la bibliographie."

msgid "Output COinS"
msgstr "Produire des COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Permet à Zotero et à des outils similaires de détecter les citations sur la page."

msgid "Output CSL-JSON"
msgstr "Produire du CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "Rend les données de citation réutilisables par des outils et services académiques."

msgid "Exports"
msgstr "Exports"

msgid "Copy bibliography"
msgstr "Copier la bibliographie"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "Copie la bibliographie actuelle en texte brut dans l’ordre et le style actuels."

msgid "Download CSL-JSON"
msgstr "Télécharger le CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Télécharge la bibliographie actuelle sous forme de données de citation structurées."

msgid "Download BibTeX"
msgstr "Télécharger le BibTeX"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "Télécharge la bibliographie actuelle en BibTeX pour les gestionnaires de références et les flux de rédaction académique."

msgid "Download RIS"
msgstr "Télécharger le RIS"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "Télécharge la bibliographie actuelle en RIS pour les gestionnaires de citations et les flux d’import/export."

msgid "Notification"
msgstr "Notification"

msgid "Publication Type"
msgstr "Type de publication"

msgid "Select a publication type"
msgstr "Sélectionnez un type de publication"

msgid "Save"
msgstr "Enregistrer"

msgid "Cancel"
msgstr "Annuler"

msgid "Post not found."
msgstr "Publication introuvable."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Désolé, vous n’êtes pas autorisé à lire cette bibliographie."

msgid "Bibliography block not found for the requested index."
msgstr "Bloc de bibliographie introuvable pour l’index demandé."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID de la publication à inspecter pour les blocs de bibliographie."

msgid "Zero-based bibliography block index within the post."
msgstr "Index de bloc de bibliographie basé sur zéro dans la publication."

msgid "Response format: json, text, or csl-json."
msgstr "Format de réponse : json, text ou csl-json."
