msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "आयात किया गया मेटाडेटा अधूरा हो सकता है। प्रकाशित करने से पहले सत्यापित करें।"

msgid "Add citations"
msgstr "उद्धरण जोड़ें"

msgid "Paste / Import"
msgstr "पेस्ट / आयात"

msgid "Manual Entry"
msgstr "मैन्युअल प्रविष्टि"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "पुस्तकों, लेखों, अध्यायों और वेबपृष्ठों के लिए समर्थित शैलियों में DOI, BibTeX प्रविष्टियाँ और उद्धरण जोड़ें। कई स्वरूपित उद्धरणों को खाली पंक्ति से अलग करें।"

msgid "Resolving…"
msgstr "प्रक्रिया चल रही है…"

msgid "Add"
msgstr "जोड़ें"

msgid "Clear"
msgstr "साफ़ करें"

msgid "Author(s)"
msgstr "लेखक"

msgid "Title"
msgstr "शीर्षक"

msgid "Container"
msgstr "कंटेनर"

msgid "Publisher"
msgstr "प्रकाशक"

msgid "Year"
msgstr "वर्ष"

msgid "Pages"
msgstr "पृष्ठ"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "उद्धरण फ़ॉर्म छिपाएँ"

msgid "Show citation form"
msgstr "उद्धरण फ़ॉर्म दिखाएँ"

msgid "Settings"
msgstr "सेटिंग्स"

msgid "source"
msgstr "स्रोत"

msgid "sources"
msgstr "स्रोत"

msgid "Citation Style"
msgstr "उद्धरण शैली"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "शैली बदलने पर स्वचालित रूप से बने उद्धरण फिर से स्वरूपित होते हैं और मैन्युअल परिवर्तन सुरक्षित रहते हैं।"

msgid "Visible Heading"
msgstr "दृश्यमान शीर्षक"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "जब कम से कम एक उद्धरण मौजूद हो, तब साइट के फ्रंटएंड पर ग्रंथसूची के ऊपर दिखाया जाने वाला वैकल्पिक शीर्षक।"

msgid "Output JSON-LD"
msgstr "JSON-LD आउटपुट"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "यह खोज इंजनों और अन्य उपकरणों को ग्रंथसूची समझने में मदद करता है।"

msgid "Output COinS"
msgstr "COinS आउटपुट"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "यह Zotero और समान उपकरणों को पृष्ठ पर उद्धरण पहचानने देता है।"

msgid "Output CSL-JSON"
msgstr "CSL-JSON आउटपुट"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "यह उद्धरण डेटा को शैक्षणिक उपकरणों और सेवाओं द्वारा पुन: उपयोग योग्य बनाता है।"

msgid "Exports"
msgstr "निर्यात"

msgid "Copy bibliography"
msgstr "ग्रंथसूची कॉपी करें"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "वर्तमान ग्रंथसूची को वर्तमान क्रम और शैली में साधारण पाठ के रूप में कॉपी करता है।"

msgid "Download CSL-JSON"
msgstr "CSL-JSON डाउनलोड करें"

msgid "Downloads the current bibliography as structured citation data."
msgstr "वर्तमान ग्रंथसूची को संरचित उद्धरण डेटा के रूप में डाउनलोड करता है।"

msgid "Download BibTeX"
msgstr "BibTeX डाउनलोड करें"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "वर्तमान ग्रंथसूची को संदर्भ प्रबंधक और अकादमिक लेखन कार्यप्रवाहों के लिए BibTeX के रूप में डाउनलोड करता है।"

msgid "Download RIS"
msgstr "RIS डाउनलोड करें"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "वर्तमान ग्रंथसूची को उद्धरण प्रबंधक और आयात/निर्यात कार्यप्रवाहों के लिए RIS के रूप में डाउनलोड करता है।"

msgid "Notification"
msgstr "सूचना"

msgid "Publication Type"
msgstr "प्रकाशन प्रकार"

msgid "Select a publication type"
msgstr "प्रकाशन प्रकार चुनें"

msgid "Save"
msgstr "सहेजें"

msgid "Cancel"
msgstr "रद्द करें"

msgid "Post not found."
msgstr "पोस्ट नहीं मिली।"

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "क्षमा करें, आपको यह ग्रंथसूची पढ़ने की अनुमति नहीं है।"

msgid "Bibliography block not found for the requested index."
msgstr "अनुरोधित इंडेक्स के लिए ग्रंथसूची ब्लॉक नहीं मिला।"

msgid "Post ID to inspect for bibliography blocks."
msgstr "ग्रंथसूची ब्लॉकों की जाँच के लिए पोस्ट ID।"

msgid "Zero-based bibliography block index within the post."
msgstr "पोस्ट के भीतर शून्य-आधारित ग्रंथसूची ब्लॉक इंडेक्स।"

msgid "Response format: json, text, or csl-json."
msgstr "प्रतिक्रिया प्रारूप: json, text, या csl-json।"
